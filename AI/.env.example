# MongoDB (cùng cluster/DB với BE)
MONGODB_URI=mongodb://127.0.0.1:27017
DB_NAME=taskmate

# OpenAI — tạo key tại https://platform.openai.com/api-keys (KHÔNG commit key thật)
OPENAI_API_KEY=
